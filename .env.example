# Modelos locales (implícitamente Ollama)
LOCAL_MODELS=llama3.2:latest

# Modelos remotos por proveedor (solo los que tienen API key configurada)
REMOTE_MODELS_OPENAI=
REMOTE_MODELS_ANTHROPIC=
REMOTE_MODELS_GEMINI=
REMOTE_MODELS_OPENROUTER=

# API keys (configura las que quieras usar)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Infraestructura
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Config del experimento
LANGUAGE=es
TEMPERATURE=0.2
PROMPT_VERSION=v1
SCORE_SCALE_MIN=0
SCORE_SCALE_MAX=10